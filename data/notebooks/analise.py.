from googleapiclient.discovery import build
from datetime import datetime, timezone
import pandas as pd

# PARAMETROS

API_KEY = "CHAVE_API"
CHANNEL_ID = "ID_CANAL"
SPLIT_DEFINITIONS = {
    "1º SPLIT": {
        "Pré":   (datetime(2025, 1, 18, tzinfo=timezone.utc), datetime(2025, 1, 24, tzinfo=timezone.utc)),
        "Split": (datetime(2025, 1, 25, tzinfo=timezone.utc), datetime(2025, 2, 23, tzinfo=timezone.utc)),
        "Pós":   (datetime(2025, 2, 24, tzinfo=timezone.utc), datetime(2025, 3, 2, tzinfo=timezone.utc)),
    },
    "2º SPLIT": {
        "Pré":   (datetime(2025, 3, 29, tzinfo=timezone.utc), datetime(2025, 4, 4, tzinfo=timezone.utc)),
        "Split": (datetime(2025, 4, 5, tzinfo=timezone.utc), datetime(2025, 5, 18, tzinfo=timezone.utc)),
        "Pós":   (datetime(2025, 5, 19, tzinfo=timezone.utc), datetime(2025, 5, 25, tzinfo=timezone.utc)),
    },
    "3º SPLIT": {
        "Pré":   (datetime(2025, 7, 19, tzinfo=timezone.utc), datetime(2025, 7, 25, tzinfo=timezone.utc)),
        "Split": (datetime(2025, 7, 26, tzinfo=timezone.utc), datetime(2025, 9, 7, tzinfo=timezone.utc)),
        "Pós":   (datetime(2025, 9, 8, tzinfo=timezone.utc), datetime(2025, 9, 14, tzinfo=timezone.utc)),
    }
}

#CONFIGURACOES

def get_youtube_service():
    return build("youtube", "v3", developerKey=API_KEY)

def get_channel_details(youtube, channel_id):
    request = youtube.channels().list(
        part="snippet,topicDetails,contentDetails",
        id=channel_id
    )
    response = request.execute()

    if not response["items"]:
        raise ValueError("Canal não encontrado.")

    item = response["items"][0]

    channel_name = item["snippet"]["title"]
    topics = item.get("topicDetails", {}).get("topicCategories", [])
    topics = [t.split("/")[-1].replace("_", " ") for t in topics]
    uploads_id = item["contentDetails"]["relatedPlaylists"]["uploads"]

    return channel_name, topics, uploads_id

def get_all_videos(youtube, playlist_id):
    videos = []
    next_page_token = None

    while True:
        pl_request = youtube.playlistItems().list(
            part="contentDetails",
            playlistId=playlist_id,
            maxResults=50,
            pageToken=next_page_token
        )
        pl_response = pl_request.execute()

        video_ids = [item["contentDetails"]["videoId"] for item in pl_response["items"]]

        if video_ids:
            vid_request = youtube.videos().list(
                part="snippet,statistics",
                id=",".join(video_ids)
            )
            vid_response = vid_request.execute()

            for item in vid_response["items"]:
                pub_date = datetime.fromisoformat(
                    item["snippet"]["publishedAt"].replace("Z", "+00:00")
                )

                videos.append({
                    "video_id": item["id"],
                    "title": item["snippet"]["title"],
                    "published_at": pub_date,
                    "views": int(item["statistics"].get("viewCount", 0)),
                    "url": f"https://www.youtube.com/watch?v={item['id']}"
                })

        next_page_token = pl_response.get("nextPageToken")
        if not next_page_token:
            break

    return videos

def get_global_date_range(split_definitions):
    start_dates = []
    end_dates = []

    for split in split_definitions.values():
        for start, end in split.values():
            start_dates.append(start)
            end_dates.append(end.replace(hour=23, minute=59, second=59))

    return min(start_dates), max(end_dates)

def filter_videos_by_date(videos, start_date, end_date):
    return [
        v for v in videos
        if start_date <= v["published_at"] <= end_date
    ]

def analyze_splits(videos):
    rows = []

    for split, periods in SPLIT_DEFINITIONS.items():
        for fase, (start, end) in periods.items():
            end = end.replace(hour=23, minute=59, second=59)

            filtered = [
                v for v in videos
                if start <= v["published_at"] <= end
            ]

            qtd = len(filtered)
            media = sum(v["views"] for v in filtered) / qtd if qtd > 0 else 0

            rows.append({
                "Split": split,
                "Fase": fase,
                "Qtd_Videos": qtd,
                "Media_Views": round(media, 2)
            })

    return pd.DataFrame(rows)

# MAIN

def main():
    try:
        youtube = get_youtube_service()

        # Dados do canal
        name, topics, uploads_id = get_channel_details(youtube, CHANNEL_ID)

        print(f"\nCANAL: {name}")
        print(f"TÓPICOS: {', '.join(topics)}")

        # Coleta de TODOS os vídeos
        all_videos = get_all_videos(youtube, uploads_id)

        if not all_videos:
            print("Nenhum vídeo encontrado.")
            return

        # Definir intervalo oficial dos Splits
        global_start, global_end = get_global_date_range(SPLIT_DEFINITIONS)

        # Filtrar vídeos dentro do intervalo
        videos_filtrados = filter_videos_by_date(
            all_videos,
            global_start,
            global_end
        )

        if not videos_filtrados:
            print(" Nenhum vídeo dentro do intervalo dos Splits.")
            return

        # TABELA DE VÍDEOS (BASE ANALÍTICA)
        df_videos = pd.DataFrame(videos_filtrados)
        df_videos.to_csv(
            "TIME_splits_2025.csv",
            index=False,
            encoding="utf-8-sig"
        )

        # Vídeo mais assistido (somente do recorte)
        best_video = df_videos.loc[df_videos["views"].idxmax()]

        print(" VÍDEO MAIS ASSISTIDO NO PERÍODO DOS SPLITS")
        print(f"Título: {best_video['title']}")
        print(f"Views: {best_video['views']:,}")
        print(f"Link: {best_video['url']}")

        # Métricas por Split
        df_splits = analyze_splits(videos_filtrados)
        df_splits.to_csv(
            "TIME_metricas_por_split_2025.csv",
            index=False,
            encoding="utf-8-sig"
        )

        print("CSVs GERADOS COM SUCESSO")

    except Exception as e:
        print(f"Erro: {e}")

if __name__ == "__main__":
    main()

