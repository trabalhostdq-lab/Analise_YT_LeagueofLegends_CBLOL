import pandas as pd
import gradio as gr
from google.colab import userdata
from llama_index.llms.groq import Groq
from llama_index.core import Settings
from llama_index.experimental.query_engine.pandas import PandasQueryEngine
from fpdf import FPDF
import seaborn as sns
import matplotlib.pyplot as plt

# --- 1. CARREGAR DADOS ---
df = pd.read_csv('RED_FINAL.csv', encoding='latin-1', sep=None, engine='python')

# --- 2. CONFIGURAR ROBÔ ---
key = userdata.get('GROQ_API')
Settings.llm = Groq(model="llama-3.3-70b-versatile", api_key=key)
query_engine = PandasQueryEngine(df=df, verbose=True)

# --- 3. LOGICA DE MEMÓRIA ---
historico_conversa = []

def realizar_analise(pergunta):
    resposta = str(query_engine.query(f"{pergunta}. Responda em Português BR."))
    historico_conversa.append({"pergunta": pergunta, "resposta": resposta})
    return resposta

def criar_relatorio_pdf():
    if not historico_conversa: return None
    pdf = FPDF()
    pdf.add_page()
    pdf.set_font("Arial", 'B', 16)
    pdf.cell(200, 10, txt="Relatório Acumulado", ln=True, align='C')
    pdf.ln(10)
    for i, item in enumerate(historico_conversa, 1):
        pdf.set_font("Arial", 'B', 12)
        pdf.multi_cell(0, 10, txt=f"PERGUNTA ({i}): {item['pergunta']}".encode('latin-1', 'replace').decode('latin-1'))
        pdf.set_font("Arial", size=12)
        pdf.multi_cell(0, 10, txt=f"RESPOSTA ({i}): {item['resposta']}".encode('latin-1', 'replace').decode('latin-1'))
        pdf.ln(5)
    nome = "relatorio_dinamico.pdf"
    pdf.output(nome)
    return nome

# --- NOVIDADE: FUNÇÃO QUE GERA QUALQUER GRÁFICO ---
def gerar_grafico_ia(pergunta_usuario):
    # Pedimos para a IA criar o código de visualização baseado na pergunta
    prompt_grafico = f"Baseado no dataframe 'df', gere APENAS o código Python usando Seaborn ou Matplotlib para: {pergunta_usuario}. Não use plt.show(), apenas crie a figura 'fig'."

    # O query_engine já sabe transformar texto em código pandas/plot!
    instrucao = query_engine.query(f"Gere o código para um gráfico de: {pergunta_usuario}. Use a biblioteca Seaborn.")

    # Aqui o Python executa o que a IA sugeriu (mágica!)
    fig, ax = plt.subplots(figsize=(10, 6))
    try:
        # A IA decide o que desenhar aqui dentro
        exec(instrucao.metadata['pandas_instruction_str'])
        plt.tight_layout()
        return plt.gcf()
    except:
        # Caso a pergunta não seja de gráfico, ele faz um padrão para não dar erro
        sns.barplot(data=df.nlargest(5, 'views'), x='views', y='title')
        return plt.gcf()

# --- 4. INTERFACE ATUALIZADA ---
with gr.Blocks(theme=gr.themes.Soft()) as app:
    gr.Markdown("# 🐺RED AJUDANTE")

    with gr.Row():
        with gr.Column():
            txt_input = gr.Textbox(label="O que você quer analisar ou desenhar?", placeholder="Ex: Gráfico de pizza por tipo de conteúdo")
            with gr.Row():
                btn_txt = gr.Button("Analisar 🔍", variant="primary")
                btn_plot = gr.Button("Gerar Gráfico da Pergunta", variant="secondary")

            res_txt = gr.Textbox(label="Resposta da IA")
            btn_pdf = gr.Button("Gerar PDF do Histórico 📄")
            res_pdf = gr.File(label="Download PDF")

        with gr.Column():
            res_plot = gr.Plot(label="Visualização Dinâmica")

    btn_txt.click(fn=realizar_analise, inputs=txt_input, outputs=res_txt)
    btn_plot.click(fn=gerar_grafico_ia, inputs=txt_input, outputs=res_plot)
    btn_pdf.click(fn=criar_relatorio_pdf, outputs=res_pdf)

app.launch(share=True)
